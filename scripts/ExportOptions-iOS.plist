<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- TestFlight / App Store Distribution. Xcode managed Automatic Signing
	     mit -allowProvisioningUpdates legt Apple-Distribution-Cert und
	     App-Store-Provisioning-Profil bei Bedarf selbst an. -->
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>export</string>
	<key>signingStyle</key>
	<string>automatic</string>
	<key>teamID</key>
	<string>D75S77JA58</string>
	<!-- Symbol-Upload an App Store Connect für Crash-Symbolication. -->
	<key>uploadSymbols</key>
	<true/>
	<!-- Bitcode ist seit Xcode 14 deprecated; explizit aus. -->
	<key>uploadBitcode</key>
	<false/>
</dict>
</plist>
